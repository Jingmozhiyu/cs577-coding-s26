# Rust Compiler
RUSTC      = rustc
RFLAGS     = --edition=2021 -O

# Problems
TARGETS    = aplusb scheduling bouncers walk present surveys giveaway

.SUFFIXES:

all: $(TARGETS)

# Rule to compile a .rs file into a native binary
$(TARGETS): %: %.rs
	@# On Linux, stack size is usually handled via 'ulimit' or at the OS level,
	@# but we can try to pass linker args if on Windows/MSVC.
	$(RUSTC) $(RFLAGS) $< -o $@

# Run and compare
run:
ifdef PROBLEM
	@# 1. Ensure the Rust file is compiled
	@if [ -f "$(PROBLEM).rs" ]; then \
		$(RUSTC) $(RFLAGS) $(PROBLEM).rs -o $(PROBLEM); \
	else \
		echo "Error: $(PROBLEM).rs not found."; \
		exit 1; \
	fi
	
	@# 2. Check for the binary (handling both Linux and .exe)
	@if [ -f "$(PROBLEM)" ]; then \
		EXEC="./$(PROBLEM)"; \
	elif [ -f "$(PROBLEM).exe" ]; then \
		EXEC="./$(PROBLEM).exe"; \
	fi; \
	\
	if [ -d "tests/$(PROBLEM)" ]; then \
		for input in tests/$(PROBLEM)/*.in; do \
			if [ -f "$$input" ]; then \
				BASE=$$(basename "$$input" .in); \
				REF_OUT=$${input%.in}.out; \
				if [ ! -f "$$REF_OUT" ]; then continue; fi; \
				\
				$$EXEC < $$input > tmp.out; \
				EXIT_CODE=$$?; \
				\
				if [ $$EXIT_CODE -ne 0 ]; then \
					echo "[$$BASE] Runtime error (Exit: $$EXIT_CODE)."; \
					continue; \
				fi; \
				\
				DIFF_RESULT=$$(diff -y -Z --suppress-common-lines tmp.out "$$REF_OUT" | head -n 10); \
				if [ -z "$$DIFF_RESULT" ]; then \
					echo "[$$BASE] Accepted."; \
				else \
					echo "[$$BASE] Wrong answer:"; \
					echo "$$DIFF_RESULT"; \
				fi; \
				rm -f tmp.out; \
			fi; \
		done; \
	else \
		echo "No tests found in tests/$(PROBLEM)/, running manually:"; \
		$$EXEC; \
	fi
else
	@echo "Usage: make run PROBLEM=<problem_name>"
endif

clean:
	rm -f $(TARGETS) *.exe tmp.out

.PHONY: all clean run